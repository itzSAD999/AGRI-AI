# Primary LLM: OpenRouter only (`/api/openrouter`). Key used by Vite dev proxy and Vercel.
OPENROUTER_API_KEY=

# Optional: pin a model; if unset, OpenRouter uses openrouter/auto (automatic routing)
# VITE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Supabase (public anon key is safe in the browser)
VITE_SUPABASE_URL=https://
VITE_SUPABASE_ANON_KEY=

# Public app URL for WhatsApp share links
VITE_APP_URL=https://suafo-ai.vercel.app

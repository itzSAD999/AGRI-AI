# OpenRouter API key (used by Vite dev proxy and Vercel serverless)
OPENROUTER_API_KEY=

# Optional: OpenRouter model slug (default anthropic/claude-sonnet-4.5). See https://openrouter.ai/models
# VITE_OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Supabase (public anon key is safe in the browser)
VITE_SUPABASE_URL=https://
VITE_SUPABASE_ANON_KEY=

# Public app URL for WhatsApp share links
VITE_APP_URL=https://suafo-ai.vercel.app
